{
  "$schema": "https://biomejs.dev/schemas/2.3.14/schema.json",
  "vcs": {
    "enabled": false,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "src/**/*.html",
      "src/**/*.css",
      "src/**/*.ts"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "performance": "on",
      "security": "on",
      "style": {
        "useNamingConvention": {
          "level": "off"
        }
      },
      "a11y": "on",
      "correctness": {
        "useImportExtensions": "off"
      },
      "complexity": "on",
      "nursery": {
        "recommended": true
      }
    }
  },
  "html": {
    "formatter": {
      "enabled": true,
      "lineWidth": 120,
      "attributePosition": "auto"
    }
  },
  "javascript": {
    "globals": [
      "$",
      "_",
      "Alpine",
      "Tabulator",
      "mdc",
      "L",
      "i18next",
      "i18nextHttpBackend",
      "updateI18nTexts",
      "tailwind"
    ],
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}